# =============================================================================
# Vercel Environment Variables for iProjectX (TanStack Start / Lovable)
# Copy these exact names into Vercel → Project → Settings → Environment Variables
# Mark NEXT_PUBLIC_* for Production + Preview + Development (needed at build time)
# =============================================================================

# --- Postgres (Supabase) ---
# Project Settings → Database → Connection string
# DATABASE_URL = pooler (transaction mode); DIRECT_URL = direct / session
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.YOUR_PROJECT:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# --- Supabase Auth / API (required) ---
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...anon...

# Server-only (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service_role...
SUPABASE_SECRET_KEY=sb_secret_...

# --- App ---
NEXT_PUBLIC_APP_NAME=iProjectX
NEXT_PUBLIC_APP_URL=https://i-project-x.vercel.app

# --- Stripe (billing) ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional price ids for Team / Business checkout
# STRIPE_PRICE_TEAM=price_...
# STRIPE_PRICE_BUSINESS=price_...

# --- Cloudflare Turnstile (optional bot protection) ---
TURNSTILE_SECRET_KEY=

# --- Cloudflare R2 (optional file storage) ---
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_R2_ACCESS_KEY_ID=
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=
# CLOUDFLARE_R2_BUCKET=
# CLOUDFLARE_R2_PUBLIC_URL=https://files.yourdomain.com
