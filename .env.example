# =============================================================================
# Vercel Environment Variables for iProjectX (TanStack Start / Lovable)
# Copy names into Vercel → Project → Settings → Environment Variables
# Mark VITE_* for Production + Preview + Development (needed at build time)
# =============================================================================

# --- Supabase (required) ---
# Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Prefer publishable key (new) or legacy anon key
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# OR:
# VITE_SUPABASE_ANON_KEY=eyJhbGciOi...
# SUPABASE_ANON_KEY=eyJhbGciOi...

# Server-only (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service_role...

# --- App URL ---
APP_URL=https://i-project-x.vercel.app

# --- Stripe (billing) ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_PRICE_TEAM=price_...
STRIPE_PRICE_BUSINESS=price_...

# --- Cloudflare R2 (optional file storage) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_URL=https://files.yourdomain.com
# Optional override:
# CLOUDFLARE_R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
