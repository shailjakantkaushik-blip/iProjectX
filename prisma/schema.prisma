generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Platform-level subscription plan catalog
model Plan {
  id              String         @id @default(cuid())
  slug            String         @unique
  name            String
  description     String
  monthlyPrice    Int            // cents USD
  annualPrice     Int            // cents USD
  seatLimit       Int
  projectLimit    Int
  features        String         // JSON array of feature flags
  isEnterprise    Boolean        @default(false)
  sortOrder       Int            @default(0)
  organizations   Organization[]
  createdAt       DateTime       @default(now())
}

/// Platform-owner landing page + global feature flags
model SiteConfig {
  id                  String   @id @default("default")
  brandName           String   @default("iProjectX")
  heroTitle           String   @default("The enterprise platform for portfolio, delivery, and outcomes.")
  heroSubtitle        String   @default("Move from spreadsheet PMO tooling to a multi-tenant SaaS workspace with subscription seats, interactive delivery intelligence, and full white-label branding.")
  heroCtaLabel        String   @default("Start 14-day trial")
  heroCtaHref         String   @default("/signup")
  secondaryCtaLabel   String   @default("View plans")
  secondaryCtaHref    String   @default("/pricing")
  primaryColor        String   @default("#0F766E")
  accentColor         String   @default("#0284C7")
  secondaryColor      String   @default("#134E4A")
  logoUrl             String?
  faviconUrl          String?
  supportEmail        String?
  footerText          String   @default("Enterprise project management & delivery")
  showPricing         Boolean  @default(true)
  showSignup          Boolean  @default(true)
  enableExcelImport   Boolean  @default(true)
  enablePptExport     Boolean  @default(true)
  enablePdfExport     Boolean  @default(true)
  featureCardsJson    String   @default("[]")
  updatedAt           DateTime @updatedAt
}

/// Tenant / enterprise customer
model Organization {
  id               String         @id @default(cuid())
  name             String
  slug             String         @unique
  planId           String?
  plan             Plan?          @relation(fields: [planId], references: [id])
  billingEmail     String?
  seatCount        Int            @default(1)
  subscriptionStatus String       @default("trialing") // trialing | active | past_due | canceled
  trialEndsAt      DateTime?
  stripeCustomerId String?
  stripeSubId      String?
  // White-label branding
  brandName        String?
  logoUrl          String?
  faviconUrl       String?
  primaryColor     String         @default("#0F766E")
  accentColor      String         @default("#0EA5E9")
  secondaryColor   String         @default("#134E4A")
  customDomain     String?        @unique
  supportEmail     String?
  loginTagline     String?
  hidePoweredBy    Boolean        @default(false)
  enableExcelImport Boolean       @default(true)
  enablePptExport   Boolean       @default(true)
  enablePdfExport   Boolean       @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  members          Membership[]
  programs         Program[]
  projects         Project[]
  risks            Risk[]
  decisions        Decision[]
  actions          Action[]
  pipelineItems    PipelineItem[]
  resources        Resource[]
  releases         Release[]
  sprints          Sprint[]
  updates          Update[]
  invitations      Invitation[]
  importJobs       ImportJob[]
  invoices         Invoice[]
}

/// Stripe / enterprise invoice issued to an organization
model Invoice {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stripeInvoiceId  String?      @unique
  stripeCustomerId String?
  number           String?
  status           String       @default("draft") // draft | open | paid | void | uncollectible | payment_failed
  amountDue        Int          @default(0) // cents
  amountPaid       Int          @default(0) // cents
  currency         String       @default("usd")
  description      String?
  planSlug         String?
  seatCount        Int?
  interval         String?      // month | year
  hostedInvoiceUrl String?
  invoicePdf       String?
  dueDate          DateTime?
  paidAt           DateTime?
  createdByUserId  String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([organizationId])
  @@index([status])
}

model User {
  id              String       @id @default(cuid())
  email           String       @unique
  name            String
  /// Supabase Auth user id (auth.users.id). Preferred login identity.
  authUserId      String?      @unique
  /// Legacy local hash — unused when Supabase Auth is enabled.
  passwordHash    String?
  avatarUrl       String?
  isPlatformAdmin Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  memberships     Membership[]
  invitations     Invitation[] @relation("InvitedBy")
  importJobs      ImportJob[]
}

model Membership {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("pm") // owner | admin | executive | bu_lead | pm
  businessUnits  String       @default("[]") // JSON array for bu_lead scoping
  createdAt      DateTime     @default(now())

  @@unique([organizationId, userId])
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String       @default("pm")
  token          String       @unique
  invitedById    String?
  invitedBy      User?        @relation("InvitedBy", fields: [invitedById], references: [id])
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime     @default(now())
}

model Program {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  owner          String?
  sponsor        String?
  budget         Float        @default(0)
  forecast       Float        @default(0)
  startFy        String?
  endFy          String?
  status         String       @default("Active")
  projects       Project[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model Project {
  id                 String       @id @default(cuid())
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code               String
  name               String
  programId          String?
  program            Program?     @relation(fields: [programId], references: [id])
  theme              String?
  portfolioCategory  String       @default("Business Strategic")
  businessUnit       String?
  sponsor            String?
  deliveryLead       String?
  pm                 String?
  priority           String       @default("Medium")
  investmentType     String?
  deliveryMethod     String       @default("Waterfall")
  fundingType        String       @default("CAPEX")
  governanceChannel  String       @default("Channel A")
  financialYear      String?
  startDate          DateTime?
  endDate            DateTime?
  progress           Float        @default(0)
  funding            Float        @default(0)
  spend              Float        @default(0)
  forecast           Float        @default(0)
  benefitsTarget     Float        @default(0)
  benefitsRealised   Float        @default(0)
  status             String       @default("Active")
  rag                String       @default("Green")
  stage              String       @default("Discovery")
  description        String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  risks              Risk[]
  decisions          Decision[]
  actions            Action[]
  stageGates         StageGate[]
  milestones         Milestone[]
  financialMonths    FinancialMonth[]
  resources          Resource[]
  sprints            Sprint[]
  releases           Release[]
  brief              ProjectBrief?

  @@unique([organizationId, code])
  @@index([organizationId])
}

model ProjectBrief {
  id                   String   @id @default(cuid())
  projectId            String   @unique
  project              Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  strategicAlignment   String?
  problemStatement     String?
  proposedSolution     String?
  scope                String?
  outOfScope           String?
  fundingAsk           Float    @default(0)
  expectedBenefits     String?
  keyRisks             String?
  assumptions          String?
  successMetrics       String?
  optionsConsidered    String?
  recommendation       String?
  stakeholderSummary   String?
  updatedAt            DateTime @updatedAt
}

model ImportJob {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?        @relation(fields: [userId], references: [id])
  filename       String
  status         String       @default("completed")
  rowsUpserted   Int          @default(0)
  errorCount     Int          @default(0)
  summary        String?
  createdAt      DateTime     @default(now())
}

model StageGate {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  channel      String
  stage        String
  nextGate     String?
  gateStatus   String   @default("Pending")
  plannedDate  DateTime?
  actualDate   DateTime?
  outcome      String?
  checklistPct Float    @default(0)
  daysLate     Int      @default(0)
}

model Milestone {
  id           String    @id @default(cuid())
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name         String
  plannedDate  DateTime?
  forecastDate DateTime?
  actualDate   DateTime?
  status       String    @default("Planned")
  owner        String?
}

model FinancialMonth {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  month     String
  year      Int
  capex     Float    @default(0)
  opex      Float    @default(0)
  actual    Float    @default(0)
  forecast  Float    @default(0)
  variance  Float    @default(0)
  pv        Float    @default(0)
  ev        Float    @default(0)
}

model Risk {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id])
  code           String
  title          String
  description    String?
  probability    Int          @default(3)
  impact         Int          @default(3)
  velocity       Int          @default(2)
  owner          String?
  mitigation     String?
  status         String       @default("Open")
  rag            String       @default("Amber")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model Decision {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id])
  title          String
  description    String?
  owner          String?
  decidedOn      DateTime?
  outcome        String?
  status         String       @default("Pending")
  createdAt      DateTime     @default(now())
}

model Action {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id])
  title          String
  owner          String?
  dueDate        DateTime?
  priority       String       @default("Medium")
  status         String       @default("Open")
  createdAt      DateTime     @default(now())
}

model PipelineItem {
  id                 String       @id @default(cuid())
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code               String
  title              String
  businessUnit       String?
  strategicAlignment Int          @default(3)
  benefitValue       Int          @default(3)
  riskReduction      Int          @default(2)
  compliance         Int          @default(2)
  complexity         Int          @default(3)
  priorityScore      Float        @default(0)
  estBudget          Float        @default(0)
  decision           String       @default("Under Review")
  sponsor            String?
  createdAt          DateTime     @default(now())

  @@index([organizationId])
}

model Resource {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id])
  name           String
  skill          String?
  role           String?
  month          String?
  allocationPct  Float        @default(0)
  capacityPct    Float        @default(100)
}

model Sprint {
  id           String    @id @default(cuid())
  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId    String?
  project      Project?  @relation(fields: [projectId], references: [id])
  name         String
  startDate    DateTime?
  endDate      DateTime?
  committedPts Int       @default(0)
  completedPts Int       @default(0)
  status       String    @default("Planned")
}

model Release {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id])
  version        String
  title          String
  releaseType    String       @default("Minor")
  environment    String       @default("Production")
  plannedDate    DateTime?
  actualDate     DateTime?
  status         String       @default("Planned")
}

model Update {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  body           String
  category       String       @default("General")
  createdAt      DateTime     @default(now())
}
